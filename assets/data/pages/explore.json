            "icon": "bi-bar-chart-line-fill",
            "soon": true,
            "order": 3
          },
          {
            "id": "data-science",
            "title": "Data Science & ML",
            "description": "Statistical modeling, experimentation, and predictive analytics.",
            "longDescription": "Data science combines statistics, programming, and domain knowledge to build models, run experiments, and extract patterns that guide strategic decisions.",
            "icon": "bi-bezier2",
            "soon": true,
            "order": 5
          },
          {
            "id": "cloud-dataops",
            "title": "Cloud & DataOps",
            "description": "Cloud computing, CI/CD, observability, and quality for data systems.",
            "longDescription": "Cloud computing, CI/CD, observability, and quality for data systems. DataOps applies software engineering practices to data pipelines — version control, testing, monitoring, and deployment automation for trustworthy data delivery.",
